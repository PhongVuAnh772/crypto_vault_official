{
  "expo": {
    "name": "CryptoVault",
    "slug": "CryptoVault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_app.png",
    "scheme": "cryptovault",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phongvuanh772.CryptoVault",
      "googleServicesFile": "./ios/GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon_app.png",
        "googleServicesFile": "./android/app/google-services.json",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.phongvuanh772.CryptoVault"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
   "plugins": [
            "expo-asset",
            [
                "react-native-permissions",
                {
                    "iosPermissions": ["Camera"]
                }
            ],
            [
                "expo-dev-launcher",
                {
                    "launchMode": "most-recent"
                }
            ],
            "expo-router",
            [
                "react-native-auth0",
                {
                    "domain": "dev-eeczycwj8h12hym0.us.auth0.com"
                }
            ],
            "@react-native-firebase/app",
            "@react-native-firebase/crashlytics",
            [
                "expo-build-properties",
                {
                    "ios": {
                        "useFrameworks": "static"
                    }
                }
            ]
        ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
