{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ES2021",
    "lib": [
      "es2015",
      "dom"
    ],
    "module": "commonjs",
    "jsx": "react",
    "strict": true,
    "types": ["victory"],
    "baseUrl": "./",
    "paths": {
      "@src/*": [
        "app/src/*"
      ],
      "@assets/*": [
        "app/src/assets/*"
      ],
      "@components/*": [
        "app/src/components/*"
      ],
      "@core/*": [
        "app/src/core/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "victory-native.d.ts"
  ]
}
